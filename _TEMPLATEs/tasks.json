{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build & Run",
            "type": "shell",
            "command": "g++ -std=c++14 -Wl,--stack=1000000000 $fileName -o $fileNameWithoutExt && $dir$fileNameWithoutExt < in.txt > out.txt",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "options": {
                "shell": {
                    "executable": "cmd.exe",
                    "args": [
                        "/c"
                    ]
                }
            },
            "problemMatcher": [
                "$gcc"
            ]
        }
    ]
}